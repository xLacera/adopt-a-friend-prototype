# ==========================================
# ARCHIVO DE PLANTILLA DE VARIABLES DE ENTORNO
# ==========================================
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env" (solo .env, eliminando el .example)
# 2. Las variables aquí puestas se cargarán en el backend cuando uses 'npm run dev'.
# 3. Nunca subas tu archivo .env real a GitHub. Todo lo que dejes en tu .env será privado y tuyo.

# URL de conexión a la base de datos (Ejemplo para Postgres). 
# Reemplaza 'usuario', 'contraseña', y 'nombre_db' con los datos de tu propia base de datos local instalada.
DATABASE_URL="postgresql://usuario:contrasena@localhost:5432/nombre_db"

# Llave secreta para JWT (Utilizada para generar las cookies o tokens cuando la gente Inicia Sesión)
# Puedes cambiarla a cualquier código, frase secreta aleatoria o número seguro en tu entorno local.
JWT_SECRET="mi_clave_secreta_super_segura_123"

# Puerto en el que la API arrancará automáticamente. 
# Importante: El Frontend está configurado para buscar el puerto 3001. No lo cambies a menos que edites ambos.
PORT=3001
